#!/usr/bin/env python3
from __future__ import annotations

import json
import os
import sys


ENV_PATH = os.environ.get("MTPROTO_MANAGED_ENV_PATH", "/etc/mtproxy/vpnbot/mtproxy.env")

# Security: only these binaries may be exec'd; guards against a tampered env file causing arbitrary RCE
_ALLOWED_BINARY_PATHS: frozenset[str] = frozenset({
    "/usr/local/bin/mtproto-proxy",
})

# Security: only honour these keys from the env file (mirrors the apply helper's
# allowlist) so an unexpected key in a tampered file is ignored, not acted upon.
_ALLOWED_ENV_KEYS: frozenset[str] = frozenset({
    "MTPROTO_BINARY_PATH",
    "MTPROTO_RUN_USER",
    "MTPROTO_RUN_GROUP",
    "MTPROTO_PROXY_SECRET_PATH",
    "MTPROTO_PROXY_MULTI_CONF_PATH",
    "MTPROTO_MANAGED_SECRETS_PATH",
    "MTPROTO_PORT",
    "MTPROTO_INTERNAL_STATS_PORT",
    "MTPROTO_WORKERS",
})

# Numeric fields validated before they reach the proxy argv.
_PORT_KEYS = ("MTPROTO_PORT", "MTPROTO_INTERNAL_STATS_PORT")


def read_env(path: str) -> dict[str, str]:
    result: dict[str, str] = {}
    with open(path, "r", encoding="utf-8") as file:
        for raw_line in file:
            line = raw_line.strip()
            if not line or line.startswith("#") or "=" not in line:
                continue
            key, value = line.split("=", 1)
            if key not in _ALLOWED_ENV_KEYS:
                continue
            result[key] = value
    return result


def _require_port(env: dict[str, str], key: str) -> str:
    raw = env[key]
    if not raw.isdigit() or not (1 <= int(raw) <= 65535):
        print(f"error: {key} is not a valid port: {raw!r}", file=sys.stderr)
        raise SystemExit(1)
    return raw


def main() -> None:
    env = read_env(ENV_PATH)
    binary_path = env["MTPROTO_BINARY_PATH"]
    # Security: validate binary path against allowlist before execv
    if binary_path not in _ALLOWED_BINARY_PATHS:
        print(f"error: MTPROTO_BINARY_PATH not in allowlist: {binary_path!r}", file=sys.stderr)
        raise SystemExit(1)
    # Validate numeric fields and workers before building argv.
    for port_key in _PORT_KEYS:
        _require_port(env, port_key)
    if not env["MTPROTO_WORKERS"].isdigit():
        print(f"error: MTPROTO_WORKERS is not numeric: {env['MTPROTO_WORKERS']!r}", file=sys.stderr)
        raise SystemExit(1)
    with open(env["MTPROTO_MANAGED_SECRETS_PATH"], "r", encoding="utf-8") as file:
        document = json.load(file)
    runtime_items = document.get("runtime_secrets") or document.get("secrets") or []
    args = [
        binary_path,
        "-u",
        env["MTPROTO_RUN_USER"],
        "-p",
        env["MTPROTO_INTERNAL_STATS_PORT"],
        "-H",
        env["MTPROTO_PORT"],
    ]
    for item in runtime_items:
        secret = str(item.get("secret") or "")
        if secret:
            args.extend(["-S", secret])
    args.extend(
        [
            "--aes-pwd",
            env["MTPROTO_PROXY_SECRET_PATH"],
            env["MTPROTO_PROXY_MULTI_CONF_PATH"],
            "-M",
            env["MTPROTO_WORKERS"],
        ]
    )
    os.execv(binary_path, args)


if __name__ == "__main__":
    main()
