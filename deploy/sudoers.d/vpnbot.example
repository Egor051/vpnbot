# Production helper-mode sudoers template for vpn-bot.
# Validate any installed copy first:
#   visudo -cf /etc/sudoers.d/vpnbot
#
# Install helpers as root:root 0755 files under /usr/local/sbin and install
# this sudoers file as root:root 0440:
#   install -o root -g root -m 0755 deploy/helpers/vpnbot-socks5-user /usr/local/sbin/vpnbot-socks5-user
#   install -o root -g root -m 0755 deploy/helpers/vpnbot-xray-apply /usr/local/sbin/vpnbot-xray-apply
#   install -o root -g root -m 0755 deploy/helpers/vpnbot-awg-apply /usr/local/sbin/vpnbot-awg-apply
#   install -o root -g root -m 0755 deploy/helpers/vpnbot-mtproxy-apply /usr/local/sbin/vpnbot-mtproxy-apply
#   install -o root -g root -m 0755 scripts/vpnbot-warp-install /usr/local/sbin/vpnbot-warp-install
#   install -o root -g root -m 0755 scripts/vpnbot-warp-iface /usr/local/sbin/vpnbot-warp-iface
#   install -o root -g root -m 0755 scripts/vpnbot-warp-routes /usr/local/sbin/vpnbot-warp-routes
#   install -o root -g root -m 0755 scripts/vpnbot-warp-status /usr/local/sbin/vpnbot-warp-status
#   install -o root -g root -m 0440 deploy/sudoers.d/vpnbot.example /etc/sudoers.d/vpnbot
#
# Wildcard arguments below are limited to fixed helper entrypoints. The helpers
# are the security boundary and must validate all actions, paths, prefixes, and
# staged file contents strictly. This file grants no raw account-management,
# service-manager, file-copy, Xray, AWG, WG, or MTProxy binaries.

Defaults:vpn-bot env_reset
Defaults:vpn-bot secure_path="/usr/local/sbin:/usr/sbin:/usr/bin:/sbin:/bin"

Cmnd_Alias VPNBOT_SOCKS5 = \
    /usr/local/sbin/vpnbot-socks5-user status, \
    /usr/local/sbin/vpnbot-socks5-user exists vpn_socks_*, \
    /usr/local/sbin/vpnbot-socks5-user create vpn_socks_*, \
    /usr/local/sbin/vpnbot-socks5-user set-password vpn_socks_*, \
    /usr/local/sbin/vpnbot-socks5-user lock vpn_socks_*, \
    /usr/local/sbin/vpnbot-socks5-user delete vpn_socks_*

Cmnd_Alias VPNBOT_XRAY = \
    /usr/local/sbin/vpnbot-xray-apply apply /run/vpn-bot/xray/*, \
    /usr/local/sbin/vpnbot-xray-apply validate /run/vpn-bot/xray/*, \
    /usr/local/sbin/vpnbot-xray-apply status

Cmnd_Alias VPNBOT_AWG = \
    /usr/local/sbin/vpnbot-awg-apply apply /run/vpn-bot/awg/*, \
    /usr/local/sbin/vpnbot-awg-apply validate /run/vpn-bot/awg/*, \
    /usr/local/sbin/vpnbot-awg-apply status, \
    /usr/local/sbin/vpnbot-awg-apply show-peers, \
    /usr/local/sbin/vpnbot-awg-apply show-transfer

Cmnd_Alias VPNBOT_MTPROTO = \
    /usr/local/sbin/vpnbot-mtproxy-apply apply /run/vpn-bot/mtproxy/*, \
    /usr/local/sbin/vpnbot-mtproxy-apply status

# WARP Telegram routing module. The install helper consumes a staged config from
# the bot's private staging dir; iface/routes/status are pinned to the fixed
# tg-warp interface and /etc/amnezia/tg-warp.conf config.
Cmnd_Alias VPNBOT_WARP = \
    /usr/local/sbin/vpnbot-warp-install install /run/vpn-bot/warp/*, \
    /usr/local/sbin/vpnbot-warp-install remove, \
    /usr/local/sbin/vpnbot-warp-iface up /etc/amnezia/tg-warp.conf, \
    /usr/local/sbin/vpnbot-warp-iface down /etc/amnezia/tg-warp.conf, \
    /usr/local/sbin/vpnbot-warp-routes add tg-warp, \
    /usr/local/sbin/vpnbot-warp-routes del tg-warp, \
    /usr/local/sbin/vpnbot-warp-status tg-warp

vpn-bot ALL=(root) NOPASSWD: VPNBOT_SOCKS5, VPNBOT_XRAY, VPNBOT_AWG, VPNBOT_MTPROTO, VPNBOT_WARP
