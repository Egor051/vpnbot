# Production helper-mode sudoers template for vpn-bot.
# Validate any installed copy first:
#   visudo -cf /etc/sudoers.d/vpn-bot
#
# Install helpers as root:root 0755 files under /usr/local/sbin and install
# this sudoers file as root:root 0440:
#   install -o root -g root -m 0755 deploy/helpers/vpn-bot-socks5-user /usr/local/sbin/vpn-bot-socks5-user
#   install -o root -g root -m 0755 deploy/helpers/vpn-bot-xray-apply /usr/local/sbin/vpn-bot-xray-apply
#   install -o root -g root -m 0755 deploy/helpers/vpn-bot-awg-apply /usr/local/sbin/vpn-bot-awg-apply
#   install -o root -g root -m 0755 deploy/helpers/vpn-bot-mtproxy-apply /usr/local/sbin/vpn-bot-mtproxy-apply
#   install -o root -g root -m 0755 scripts/vpn-bot-warp-install /usr/local/sbin/vpn-bot-warp-install
#   install -o root -g root -m 0755 scripts/vpn-bot-warp-iface /usr/local/sbin/vpn-bot-warp-iface
#   install -o root -g root -m 0755 scripts/vpn-bot-warp-routes /usr/local/sbin/vpn-bot-warp-routes
#   install -o root -g root -m 0755 scripts/vpn-bot-warp-status /usr/local/sbin/vpn-bot-warp-status
#   install -o root -g root -m 0440 deploy/sudoers.d/vpn-bot.example /etc/sudoers.d/vpn-bot
#
# Wildcard arguments below are limited to fixed helper entrypoints. The helpers
# are the security boundary and must validate all actions, paths, prefixes, and
# staged file contents strictly. This file grants no raw account-management,
# service-manager, file-copy, Xray, AWG, WG, or MTProxy binaries.
#
# NOTE on sudo glob semantics: in command ARGUMENTS a trailing "*" is matched
# against the whole concatenated argument string, so it also matches "/", spaces
# and additional argv elements. A pattern like ".../xray/*" therefore does NOT by
# itself forbid "..", traversal, or extra arguments — every helper independently
# re-validates its argv (argparse rejects extra/unknown args), resolves and
# confines staged paths to its fixed staging root, and rejects symlinks. The
# remove/up/down/add/del/status verbs use no wildcard and are fully pinned.

Defaults:vpn-bot env_reset
Defaults:vpn-bot secure_path="/usr/local/sbin:/usr/sbin:/usr/bin:/sbin:/bin"

Cmnd_Alias VPN_BOT_SOCKS5 = \
    /usr/local/sbin/vpn-bot-socks5-user status, \
    /usr/local/sbin/vpn-bot-socks5-user exists vpn_socks_*, \
    /usr/local/sbin/vpn-bot-socks5-user create vpn_socks_*, \
    /usr/local/sbin/vpn-bot-socks5-user set-password vpn_socks_*, \
    /usr/local/sbin/vpn-bot-socks5-user lock vpn_socks_*, \
    /usr/local/sbin/vpn-bot-socks5-user delete vpn_socks_*

Cmnd_Alias VPN_BOT_XRAY = \
    /usr/local/sbin/vpn-bot-xray-apply apply /run/vpn-bot/xray/*, \
    /usr/local/sbin/vpn-bot-xray-apply validate /run/vpn-bot/xray/*, \
    /usr/local/sbin/vpn-bot-xray-apply status

Cmnd_Alias VPN_BOT_AWG = \
    /usr/local/sbin/vpn-bot-awg-apply apply /run/vpn-bot/awg/*, \
    /usr/local/sbin/vpn-bot-awg-apply validate /run/vpn-bot/awg/*, \
    /usr/local/sbin/vpn-bot-awg-apply status, \
    /usr/local/sbin/vpn-bot-awg-apply show-peers, \
    /usr/local/sbin/vpn-bot-awg-apply show-transfer

Cmnd_Alias VPN_BOT_MTPROTO = \
    /usr/local/sbin/vpn-bot-mtproxy-apply apply /run/vpn-bot/mtproxy/*, \
    /usr/local/sbin/vpn-bot-mtproxy-apply status

# WARP outbound-IP masking module. The install helper consumes a staged config
# from the bot's private staging dir; iface/routes/status are pinned to the fixed
# out-warp interface and /etc/amnezia/out-warp.conf config.
# NOTE: the iface up/down and routes add/del grants are only exercised in the legacy
# self-managed mode (WARP_MONITOR_OBSERVER_MODE=false). In the default observer model
# systemd owns the interface and its routes and the bot only reads status.
Cmnd_Alias VPN_BOT_WARP = \
    /usr/local/sbin/vpn-bot-warp-install install /run/vpn-bot/warp/*, \
    /usr/local/sbin/vpn-bot-warp-install remove, \
    /usr/local/sbin/vpn-bot-warp-iface up /etc/amnezia/out-warp.conf, \
    /usr/local/sbin/vpn-bot-warp-iface down /etc/amnezia/out-warp.conf, \
    /usr/local/sbin/vpn-bot-warp-routes add out-warp, \
    /usr/local/sbin/vpn-bot-warp-routes del out-warp, \
    /usr/local/sbin/vpn-bot-warp-status out-warp

# WARP selective-split list management. The helper reads the new list from stdin,
# validates every CIDR (python3 ipaddress), writes /etc/vpn-bot/warp-split.list
# atomically, and restarts vpn-bot-warp-split. No arguments beyond the binary
# itself — the list is piped via stdin, so no path wildcards are needed here.
#
# The split-state helper toggles the split ROUTING (table T) on/off/restart and
# reports observer status. Each verb is pinned exactly (no wildcard); it only
# manages the per-prefix routes + the root-owned marker, never the tunnel.
# The apply helper is pinned to zero arguments ("") — the list arrives on stdin — so
# sudo rejects any trailing argv, not just wildcards.
Cmnd_Alias VPN_BOT_WARP_SPLIT = \
    /usr/local/sbin/vpn-bot-warp-split-apply "", \
    /usr/local/sbin/vpn-bot-warp-split-state on, \
    /usr/local/sbin/vpn-bot-warp-split-state off, \
    /usr/local/sbin/vpn-bot-warp-split-state restart, \
    /usr/local/sbin/vpn-bot-warp-split-state status

vpn-bot ALL=(root) NOPASSWD: VPN_BOT_SOCKS5, VPN_BOT_XRAY, VPN_BOT_AWG, VPN_BOT_MTPROTO, VPN_BOT_WARP, VPN_BOT_WARP_SPLIT
