# Databases/data
*.db
*.sqlite
*.sqlite3
# SQLite runs in WAL mode (db/database.py), which creates -wal/-shm/-journal
# sidecar files next to the DB; ignore them too.
*-wal
*-shm
*-journal
*.db-wal
*.db-shm
*.db-journal
data/
!data/.gitkeep
data/*.db
data/*.sqlite
data/*.sqlite3

# Logs/runtime
logs/
*.log
*.pid
*.lock
backups/

# VPN/security-sensitive files
*.key
*.pem
*.p12
*.crt
*.csr
*.ovpn
# Ignore WireGuard/AWG server interface configs (contain private keys)
wg0.conf
awg0.conf
# Ignore MTProxy runtime configs (contain secrets)
/etc/mtproxy/**/*.conf
# Keep tracked deploy and docs configs
!deploy/*.conf
!docs/**/*.conf.example
xray-config.json
config.json.bak*
*.bak
*.backup

# Keep safe examples trackable
!*.example
!*.sample
!docs/**/*.json.example

# Local IDE/editor files
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db

# Deployment/local artifacts
dist/
build/
*.egg-info/
.cache/
tmp/
temp/
.claude/

# Installed runtime copies of tracked deploy/ sources
#
# /opt/vpn-service is BOTH the git checkout and the install root, so anything
# installed into the checkout tree shows up as untracked and trips the clean-tree
# gate in scripts/deploy.sh (git status --porcelain). The MTProxy managed-mode
# wrapper is installed from its tracked source deploy/run-mtproxy-managed to this
# path (see docs/proxy.md and MTPROTO_MANAGED_WRAPPER_PATH in docs/configuration.md).
# It is a runtime artifact, not a source, so it is ignored here rather than tracked:
# tracking it would create a second, drift-prone copy of the wrapper. The data/ and
# logs/ runtime directories above are ignored for the same reason.
/scripts/run-mtproxy-managed
