# Telegram
# Get this from BotFather. Never commit a real token.
BOT_TOKEN=<telegram_bot_token>
# Comma-separated numeric Telegram user IDs with superadmin access.
ADMIN_IDS=<telegram_user_id>,<telegram_user_id>

DB_PATH=/opt/vpn-service/data/vpn.db
# FULL is the safer control-plane default. NORMAL is faster but less durable on OS/power crash.
SQLITE_SYNCHRONOUS=FULL
LOG_DIR=/opt/vpn-service/logs
BOT_LOCK_PATH=/run/vpn-bot/vpn-bot.lock
BOT_DROP_PENDING_UPDATES=false
# Boolean env values are strict: use true/false, yes/no, on/off or 1/0.
# Bot UI language. Supported: ru (default) or en.
BOT_LANGUAGE=ru
# Optional HTTP health check endpoint. Leave unset to disable.
# HEALTH_HOST binds the endpoint (default 127.0.0.1); HEALTH_PORT enables it.
# HEALTH_HOST=127.0.0.1
# HEALTH_PORT=8080

# Root+api mode (default): set PRIVILEGE_HELPERS_ENABLED=false or omit. See README Xray API Mode section.
# Non-root helper mode: set PRIVILEGE_HELPERS_ENABLED=true with helper paths below.
PRIVILEGE_HELPERS_ENABLED=false
HELPER_STAGING_ROOT=/run/vpn-bot
SOCKS5_USER_HELPER_PATH=/usr/local/sbin/vpnbot-socks5-user
XRAY_APPLY_HELPER_PATH=/usr/local/sbin/vpnbot-xray-apply
AWG_APPLY_HELPER_PATH=/usr/local/sbin/vpnbot-awg-apply
MTPROTO_APPLY_HELPER_PATH=/usr/local/sbin/vpnbot-mtproxy-apply

XRAY_CONFIG_PATH=/usr/local/etc/xray/config.json
XRAY_SERVICE_NAME=xray
# api adds/removes keys without restarting Xray (no connection drops). Requires User=root and PRIVILEGE_HELPERS_ENABLED=false.
# restart and reload cause a full Xray restart on every key change; use with non-root helper mode.
XRAY_APPLY_MODE=api
# Required for api mode: must match the "tag" field on the VLESS inbound in config.json.
XRAY_INBOUND_TAG=vless-in
XRAY_PUBLIC_HOST=
XRAY_PUBLIC_PORT=443
XRAY_REALITY_PUBLIC_KEY=
XRAY_SNI=
XRAY_FLOW=xtls-rprx-vision
XRAY_FINGERPRINT=chrome
# Supported network types for generated links: tcp or raw.
XRAY_NETWORK_TYPE=tcp
XRAY_SHORT_ID=
XRAY_MANAGE_SHORT_IDS=false
XRAY_ALLOW_RESTART_ON_ROLLBACK=false
# Required for api mode: must match the dokodemo-door api inbound port in config.json.
XRAY_STATS_SERVER=127.0.0.1:10085
# Background Xray traffic-stats sampling interval in seconds (0–3600; 0 disables).
# statsquery is read without -reset (non-destructive), so manual stat views poll it
# live; this loop only keeps the cache warm between them so the dashboard stays fresh
# without user interaction. Setting 0 just drops that background freshness.
XRAY_STATS_INTERVAL=60
# --- Second VLESS transport: XHTTP over the vless-in REALITY fallback (optional) ---
# When enabled, key creation offers a transport choice: VLESS (TCP) -> the vless-in
# inbound above, and VLESS (HTTP) -> XHTTP. Leave disabled to keep behaviour
# identical to before (single TCP inbound).
#
# Topology: vless-in (:443) terminates REALITY/TLS and, via a DEFAULT catch-all
# fallback ({ "dest": 8001, "xver": 0 }, no "path"), forwards to an internal loopback
# XHTTP inbound (the fallback dest). A path-based fallback does NOT match h2 XHTTP (the
# h2 :path lives in HPACK, not the request-line), so the catch-all is mandatory; the
# path is validated on the XHTTP inbound. That inbound carries no REALITY of its own
# (security: none) and only holds the http clients[]. VLESS (HTTP) links therefore
# reuse vless-in's REALITY (pbk/sni/sid/fp) and its public :443. See
# docs/xray-xhttp-inbound.md for the one-time server-side setup.
XRAY_XHTTP_ENABLED=false
# Must match the "tag" field on the loopback XHTTP fallback-dest inbound in config.json
# (must differ from XRAY_INBOUND_TAG). Required when XRAY_XHTTP_ENABLED=true.
XRAY_XHTTP_INBOUND_TAG=vless-xhttp-reality
# Retained for back-compat; NOT used to build links anymore (http rides vless-in's
# public :443 = XRAY_PUBLIC_PORT; the XHTTP inbound itself listens on loopback).
XRAY_XHTTP_PORT=8443
# XHTTP path, used to build VLESS (HTTP) links. Must match the XHTTP inbound's
# streamSettings.xhttpSettings.path.
XRAY_XHTTP_PATH=/v1/messages/stream
# Client-side XHTTP mode written into VLESS (HTTP) links. Default stream-one: a single
# full-duplex h2 session, the cleanest fit for direct REALITY (confirmed working through
# the catch-all fallback). Switch to packet-up for request throttling on long sessions or
# CDN passthrough (xmux rotates connections there). stream-up (two-request) is only for
# environments without single-request full-duplex and is not needed on direct REALITY.
XRAY_XHTTP_MODE=stream-one
# Path to the Xray access log used for anomaly detection. Leave empty to disable.
XRAY_ACCESS_LOG_PATH=
# Staging dir for the Xray apply helper (defaults to HELPER_STAGING_ROOT/xray).
# XRAY_HELPER_STAGING_DIR=/run/vpn-bot/xray

AWG_CONFIG_PATH=/etc/amnezia/amneziawg/awg0.conf
AWG_INTERFACE=awg0
AWG_NETWORK=10.0.0.0/24
# Must be an IPv4 host address inside AWG_NETWORK, not network/broadcast.
AWG_SERVER_ADDRESS=10.0.0.1
AWG_ENDPOINT_HOST=
AWG_ENDPOINT_PORT=
AWG_SERVER_PUBLIC_KEY=
AWG_DNS=1.1.1.1
AWG_MTU=
AWG_ALLOWED_IPS=0.0.0.0/0, ::/0
AWG_PERSISTENT_KEEPALIVE=25
AWG_USE_PRESHARED_KEY=true
# Background AWG traffic-stats sampling interval in seconds (0–3600).
AWG_STATS_INTERVAL=60
# Staging dir for the AWG apply helper (defaults to HELPER_STAGING_ROOT/awg).
# AWG_HELPER_STAGING_DIR=/run/vpn-bot/awg

# WARP outbound-IP masking module (server-side AmneziaWG tunnel that hides the
# server's outbound IP for selected "spy" apps via their AllowedIPs).
# Disabled by default; enable it from the admin panel after uploading a config.
# All privileged actions go through the vpnbot-warp-* sudo helpers. Defaults below
# match the provided sudoers template. Changing WARP_CONFIG_PATH or WARP_INTERFACE
# requires matching updates to /etc/sudoers.d/vpnbot and the vpnbot-warp-* helper
# scripts; mismatches cause silent sudo failures. Change only if you know what you
# are doing.
WARP_CONFIG_PATH=/etc/amnezia/out-warp.conf
WARP_INTERFACE=out-warp
WARP_INSTALL_HELPER_PATH=/usr/local/sbin/vpnbot-warp-install
WARP_IFACE_HELPER_PATH=/usr/local/sbin/vpnbot-warp-iface
WARP_ROUTES_HELPER_PATH=/usr/local/sbin/vpnbot-warp-routes
WARP_STATUS_HELPER_PATH=/usr/local/sbin/vpnbot-warp-status
# Private staging dir for uploaded configs (defaults to HELPER_STAGING_ROOT/warp).
WARP_HELPER_STAGING_DIR=/run/vpn-bot/warp
# ICMP target the health monitor pings to decide tunnel up/down. Default is a
# Cloudflare anycast address present in typical WARP AllowedIPs. Override if your
# AllowedIPs does not cover this address, otherwise the monitor reports false failures.
WARP_PING_TARGET=162.159.140.245
# Observer mode (default true): the bot's health monitor only watches the tunnel
# (probes, DB state, admin notifications) and NEVER brings the interface up/down or
# adds/removes routes. Those are owned by systemd (awg-quick@out-warp +
# warp-routes.service). Set to false only to restore the legacy model where the bot
# manages the interface and routes itself.
WARP_MONITOR_OBSERVER_MODE=true
# Time-based switching: the monitor declares the tunnel down (and notifies admins) only
# after WARP_MONITOR_FAIL_WINDOW_SECONDS of continuous no-response, and back up only
# after WARP_MONITOR_RECOVER_WINDOW_SECONDS of continuous success — so a single dropped
# (or single recovered) ICMP probe never flaps the routing.
WARP_MONITOR_FAIL_WINDOW_SECONDS=60
WARP_MONITOR_RECOVER_WINDOW_SECONDS=60
# Adaptive probe cadence: WARP_MONITOR_INTERVAL_SECONDS during normal operation,
# dropping to the faster WARP_MONITOR_FAST_INTERVAL_SECONDS the moment a probe gets no
# response (so an outage and the start of recovery are detected quickly).
WARP_MONITOR_INTERVAL_SECONDS=10
WARP_MONITOR_FAST_INTERVAL_SECONDS=3
# Selective-split list and its privileged apply helper.
# The bot reads the file directly (0644); all writes go through the helper which
# validates every CIDR, writes atomically, and restarts vpnbot-warp-split.
# Change only if you move the file or helper to a non-default path — the sudoers
# grant for vpnbot-warp-split-apply must be updated to match.
WARP_SPLIT_LIST_PATH=/etc/vpnbot/warp-split.list
WARP_SPLIT_APPLY_HELPER_PATH=/usr/local/sbin/vpnbot-warp-split-apply
# Privileged on/off/restart/status helper for split ROUTING (table T) plus the
# root-owned intent marker it manages. The On/Off/Restart buttons in the «Сокрытие
# outbound IP» panel call this helper — it only retracts/re-applies the per-prefix
# routes and writes the marker, never the awg-quick@out-warp interface/process.
# Change only if you relocate them — the sudoers grant must be updated to match.
WARP_SPLIT_STATE_HELPER_PATH=/usr/local/sbin/vpnbot-warp-split-state
WARP_SPLIT_DISABLED_MARKER_PATH=/etc/vpnbot/warp-split.disabled
# Route LOCAL proxy egress (Dante SOCKS5, Xray VLESS, MTProto) through the WARP
# tunnel too, so the proxies' outbound IP is masked just like the AWG clients'. When
# true the Xray config writer binds the freedom outbound's egress source to the
# tunnel IP (sendThrough=<[Interface] Address>). Off by default; flip to true only as
# part of the manual WARP proxy-egress activation runbook (see README "WARP proxy
# egress"). Dante's external= and the MTProto cgroup-mark are set by vpnbot-warp-routes
# / danted.conf, not by this flag.
WARP_PROXY_EGRESS=false

DEFAULT_PROXY_TYPE=
DEFAULT_PROXY_HOST=
DEFAULT_PROXY_PORT=
DEFAULT_PROXY_LOGIN=
DEFAULT_PROXY_PASSWORD=
DEFAULT_PROXY_NOTE=

SOCKS5_ENABLED=false
SOCKS5_HOST=
SOCKS5_PORT=31337
SOCKS5_LOGIN_PREFIX=vpn_socks_
SOCKS5_SYSTEM_USER_SHELL=/usr/sbin/nologin
SOCKS5_SERVICE_NAME=danted
SOCKS5_PUBLIC_NAME=SOCKS5 Proxy
SOCKS5_NOTE=SOCKS5 Dante proxy on VDS

MTPROTO_ENABLED=false
MTPROTO_MODE=static
MTPROTO_HOST=
MTPROTO_PORT=8443
MTPROTO_SECRET=
MTPROTO_PUBLIC_NAME=Telegram MTProto Proxy
MTPROTO_NOTE=MTProto proxy for Telegram

# Managed MTProto per-user secrets mode
MTPROTO_SERVICE_NAME=mtproxy
MTPROTO_BINARY_PATH=/usr/local/bin/mtproto-proxy
MTPROTO_RUN_USER=mtproxy
MTPROTO_RUN_GROUP=mtproxy
MTPROTO_CONFIG_DIR=/etc/mtproxy
MTPROTO_PROXY_SECRET_PATH=/etc/mtproxy/proxy-secret
MTPROTO_PROXY_MULTI_CONF_PATH=/etc/mtproxy/proxy-multi.conf
MTPROTO_MANAGED_DIR=/etc/mtproxy/vpnbot
MTPROTO_MANAGED_SECRETS_PATH=/etc/mtproxy/vpnbot/managed-secrets.json
MTPROTO_MANAGED_ENV_PATH=/etc/mtproxy/vpnbot/mtproxy.env
MTPROTO_MANAGED_WRAPPER_PATH=/opt/vpn-service/scripts/run-mtproxy-managed
MTPROTO_BACKUP_DIR=/etc/mtproxy/vpnbot/backups
MTPROTO_INTERNAL_STATS_PORT=8888
MTPROTO_WORKERS=1
MTPROTO_APPLY_TIMEOUT_SECONDS=10
MTPROTO_ROLLBACK_ON_APPLY_FAILURE=true
MTPROTO_KEEP_LAST_BACKUPS=10
MTPROTO_STATS_URL=
# Staging dir for the MTProto apply helper (defaults to HELPER_STAGING_ROOT/mtproxy).
# MTPROTO_HELPER_STAGING_DIR=/run/vpn-bot/mtproxy

AUDIT_RETENTION_DAYS=180
CONFIG_BACKUP_KEEP_LAST=20

# Key expiry and trial access
# How often (seconds) to check for expiring/expired keys (0–86400).
KEY_EXPIRY_CHECK_INTERVAL=1800
# Comma-separated days-before-expiry to notify users. Empty disables notifications.
KEY_EXPIRY_NOTIFY_DAYS=
# Maximum duration (days) for trial VPN keys (1–3650).
KEY_MAX_TRIAL_DAYS=365

# Anomaly detection (suspicious traffic / concurrent-connection monitor)
# How often (seconds) to run the scan (0–86400).
ANOMALY_CHECK_INTERVAL=300
# Traffic observation window in seconds (60–86400).
ANOMALY_WINDOW_SECONDS=3600
# Minimum unique source IPs within the window to flag a key (1–1000).
ANOMALY_MIN_UNIQUE_IPS=3
# Automatically revoke flagged keys without admin confirmation.
ANOMALY_AUTO_REVOKE=false
# Cooldown before re-flagging the same key (0–86400).
ANOMALY_COOLDOWN_SECONDS=7200
# Window for concurrent-connection anomaly detection (0–86400).
ANOMALY_CONCURRENT_WINDOW_SECONDS=600

# Off-site encrypted DB backups — sent to all admins via Telegram.
# Generate key: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Decrypt: python -c "from cryptography.fernet import Fernet; open('out.db','wb').write(Fernet(b'KEY').decrypt(open('file.db.enc','rb').read()))"
# Leave empty to disable off-site backups.
OFFSITE_BACKUP_ENCRYPTION_KEY=
# Auto-backup interval in seconds (default: 604800 = 7 days). Set to 0 to disable scheduled backups.
OFFSITE_BACKUP_INTERVAL=604800
# Also send a second encrypted "recovery bundle" (.env + Xray/AWG/MTProto/WARP
# configs) alongside the DB backup, so the service can be rebuilt on a clean
# server. Encrypted with the same OFFSITE_BACKUP_ENCRYPTION_KEY. Set to false to
# send only the DB backup. The bundle is a tar.gz: decrypt as below, then `tar xzf`.
# Decrypt: python -c "from cryptography.fernet import Fernet; open('recovery.tar.gz','wb').write(Fernet(b'KEY').decrypt(open('file.tar.gz.enc','rb').read()))"
# Store OFFSITE_BACKUP_ENCRYPTION_KEY OUTSIDE the bundle — the bundle contains .env (and thus the key itself).
OFFSITE_BACKUP_INCLUDE_CONFIGS=true
# Path to the .env included in the recovery bundle. Leave empty to auto-detect the
# .env loaded at startup. Set explicitly if the bot is started from another directory.
OFFSITE_BACKUP_ENV_PATH=
