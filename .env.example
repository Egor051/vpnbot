# Telegram
# Get this from BotFather. Never commit a real token.
BOT_TOKEN=<telegram_bot_token>
# Comma-separated numeric Telegram user IDs with superadmin access.
ADMIN_IDS=<telegram_user_id>,<telegram_user_id>

# Paths
DB_PATH=/opt/vpn-service/data/vpn.db
LOG_DIR=/opt/vpn-service/logs
# systemd also sets this path in deploy/vpn-bot.service.
BOT_LOCK_PATH=/run/vpn-bot.lock

# Xray
XRAY_CONFIG_PATH=/usr/local/etc/xray/config.json
XRAY_SERVICE_NAME=xray
# Empty means: use the first inbound with settings.clients.
XRAY_INBOUND_TAG=
XRAY_PUBLIC_HOST=
XRAY_PUBLIC_PORT=443
XRAY_REALITY_PUBLIC_KEY=
XRAY_SNI=
XRAY_FLOW=xtls-rprx-vision
XRAY_FINGERPRINT=chrome
# Code default is tcp.
XRAY_NETWORK_TYPE=tcp
# Required for Xray key creation when XRAY_MANAGE_SHORT_IDS=false.
XRAY_SHORT_ID=
XRAY_MANAGE_SHORT_IDS=false
# Keep false unless you explicitly accept restart-on-rollback behavior.
XRAY_ALLOW_RESTART_ON_ROLLBACK=false
# Optional Xray stats API endpoint. Leave empty when stats API is not configured.
XRAY_STATS_SERVER=

# Legacy Xray aliases accepted by the code. Prefer the XRAY_* names above.
XRAY_SERVER_ADDRESS=
XRAY_SERVER_PORT=
XRAY_PUBLIC_KEY=
XRAY_SERVER_NAME=

# AmneziaWG
AWG_CONFIG_PATH=/etc/amnezia/amneziawg/awg0.conf
AWG_INTERFACE=awg0
AWG_NETWORK=10.0.0.0/24
AWG_SERVER_ADDRESS=10.0.0.1
AWG_ENDPOINT_HOST=
# Empty means: use ListenPort from the server config.
AWG_ENDPOINT_PORT=
# Optional if PublicKey is present in the server config.
AWG_SERVER_PUBLIC_KEY=
AWG_DNS=1.1.1.1
# Empty means: do not add MTU to generated client configs.
AWG_MTU=
AWG_ALLOWED_IPS=0.0.0.0/0, ::/0
AWG_PERSISTENT_KEEPALIVE=25
AWG_USE_PRESHARED_KEY=true

# Legacy AWG alias accepted by the code. Prefer AWG_DNS.
AWG_CLIENT_DNS=

# Default proxy / SOCKS5
# Optional seed record. Used only when proxy storage is empty.
DEFAULT_PROXY_TYPE=
DEFAULT_PROXY_HOST=
DEFAULT_PROXY_PORT=
DEFAULT_PROXY_LOGIN=
DEFAULT_PROXY_PASSWORD=
DEFAULT_PROXY_NOTE=

# Maintenance / retention
AUDIT_RETENTION_DAYS=180
CONFIG_BACKUP_KEEP_LAST=20
