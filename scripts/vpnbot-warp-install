#!/bin/bash
# vpnbot-warp-install — install or remove the WARP AmneziaWG config.
#
# Usage:
#   vpnbot-warp-install install <staged_config>
#   vpnbot-warp-install remove
#
# install: validates the AmneziaWG format, strips/normalises the config, writes
# the canonical config and the routes.list (one CIDR per line, extracted from
# AllowedIPs — never modified).
# remove: deletes the config and routes.list files from disk.
set -euo pipefail

ACTION="${1:-}"
SOURCE="${2:-}"
DEST="/etc/amnezia/out-warp.conf"
ROUTES_LIST="/etc/amnezia/out-warp-routes.list"

case "${ACTION}" in
  install)
    [[ -f "$SOURCE" ]] || { echo "Source file not found: $SOURCE" >&2; exit 1; }
    # Reject symlinks outright (parity with the Python helpers). The bot owns the
    # staging dir, so a symlinked source must never be followed into a root read.
    [[ -L "$SOURCE" ]] && { echo "Source must not be a symlink: $SOURCE" >&2; exit 1; }

    # Validate that SOURCE resolves within the allowed staging directory. The
    # comparison uses the literal staging prefix (not a resolved one), so swapping
    # the staging dir itself for a symlink is also rejected.
    ALLOWED_DIR="/run/vpn-bot/warp"
    realpath_source=$(realpath "$SOURCE")
    [[  "$realpath_source" == "$ALLOWED_DIR/"* ]] || {
        echo "Source path outside allowed dir: $SOURCE" >&2; exit 1
    }
    # From here on operate on the resolved path only.
    SRC="$realpath_source"

    # NOTE: AmneziaWG format validation AND PreUp/PostUp/PreDown/PostDown hook
    # rejection are performed inside the single O_NOFOLLOW read in the Python block
    # below — on the exact bytes that get written to $DEST. Doing them here with a
    # separate grep pass would reopen a file the bot still owns and create a TOCTOU:
    # a hook-free config could pass the check while a hook-bearing one is written to
    # disk and later executed as root by awg-quick. One read == no revalidation window.

    mkdir -p /etc/amnezia

    # Create temp files with restrictive permissions before any sensitive data is written.
    # This prevents a window where the PrivateKey is world-readable under a typical root umask.
    DEST_TMP="${DEST}.tmp.$$"
    ROUTES_TMP="${ROUTES_LIST}.tmp.$$"
    cleanup() { rm -f "$DEST_TMP" "$ROUTES_TMP"; }
    trap cleanup EXIT
    install -m 600 /dev/null "$DEST_TMP"
    install -m 600 /dev/null "$ROUTES_TMP"

    # Preprocess and write routes.list via Python
    SOURCE="$SRC" DEST_TMP="$DEST_TMP" ROUTES_TMP="$ROUTES_TMP" python3 - <<'PYEOF'
import ipaddress, os, re, sys

src = os.environ["SOURCE"]
dest = os.environ["DEST_TMP"]
routes_list = os.environ["ROUTES_TMP"]

# O_NOFOLLOW guards against a TOCTOU swap of the validated source to a symlink
# between the shell-side realpath check and this read. Every check below runs on
# THIS single read (never a separate pre-read grep pass), so a racing writer in
# the bot-owned staging dir cannot slip a hook-free config past validation while a
# hook-bearing one is what actually gets written.
fd = os.open(src, os.O_RDONLY | os.O_NOFOLLOW)
with os.fdopen(fd, "r", encoding="utf-8") as f:
    content = f.read()

# Validate the AmneziaWG format markers on the exact bytes about to be installed.
_required = (
    (r'^[ \t]*\[Interface\]', "Missing [Interface] section"),
    (r'^[ \t]*\[Peer\]', "Missing [Peer] section"),
    (r'^[ \t]*Jc[ \t]*=', "Not AmneziaWG format (missing Jc)"),
    (r'^[ \t]*S1[ \t]*=', "Not AmneziaWG format (missing S1)"),
    (r'^[ \t]*S2[ \t]*=', "Not AmneziaWG format (missing S2)"),
    (r'^[ \t]*AllowedIPs[ \t]*=', "Missing AllowedIPs"),
)
for pattern, message in _required:
    if not re.search(pattern, content, re.MULTILINE):
        print(message, file=sys.stderr)
        sys.exit(1)

# Security: reject script-execution hooks. awg-quick/wg-quick run PreUp/PostUp/
# PreDown/PostDown as root when the interface is brought up or down — a config must
# never smuggle commands across the privilege boundary. Checked (case-insensitively)
# on the same read that is written, so there is no revalidation window to race.
if re.search(r'^[ \t]*(Pre|Post)(Up|Down)[ \t]*=', content, re.MULTILINE | re.IGNORECASE):
    print("Config must not contain PreUp/PostUp/PreDown/PostDown directives", file=sys.stderr)
    sys.exit(1)

# Drop DNS (do not touch the server resolver)
content = re.sub(r'^DNS\s*=.*\n?', '', content, flags=re.MULTILINE)

# Force "Table = auto" in [Interface]. Table=auto makes awg-quick put an fwmark on
# the WireGuard socket (loop protection) and create a dedicated routing table with
# a default route via the tunnel; vpnbot-warp-routes then strips the host-bypass
# and diverts only the client subnet. Any stale value is rewritten — a disabled
# table is what broke the previous routing-loop implementation.
if re.search(r'^[ \t]*Table\s*=', content, re.MULTILINE):
    content = re.sub(
        r'^[ \t]*Table\s*=.*$',
        'Table = auto',
        content,
        count=1,
        flags=re.MULTILINE,
    )
else:
    content = re.sub(
        r'(\[Interface\])',
        r'\1\nTable = auto',
        content
    )

# Add PersistentKeepalive to [Peer] if absent
if not re.search(r'^PersistentKeepalive\s*=', content, re.MULTILINE):
    content = re.sub(
        r'(\[Peer\])',
        r'\1\nPersistentKeepalive = 25',
        content
    )

# Write the processed config to the temp file (already mode 600)
with open(dest, 'w') as f:
    f.write(content)

# Extract AllowedIPs and write routes.list (AllowedIPs itself is not modified)
match = re.search(r'^AllowedIPs\s*=\s*(.+)$', content, re.MULTILINE)
if not match:
    print("AllowedIPs not found after processing", file=sys.stderr)
    sys.exit(1)

routes = [ip.strip() for ip in match.group(1).split(',') if ip.strip()]

# Validate every token as a real CIDR here, at the root boundary, instead of
# trusting the bot-side validator. This rejects "default" and any malformed entry
# before it can reach routes.list and be fed to "ip route".
for token in routes:
    try:
        ipaddress.ip_network(token, strict=False)
    except ValueError:
        print(f"Invalid CIDR in AllowedIPs: {token}", file=sys.stderr)
        sys.exit(1)

with open(routes_list, 'w') as f:
    f.write('\n'.join(routes) + '\n')

print(f"Installed: {len(routes)} routes")
PYEOF

    # Move routes.list into place first so that, if interrupted between the two
    # renames, "config present" always implies "routes present". Then disarm trap.
    mv "$ROUTES_TMP" "$ROUTES_LIST"
    mv "$DEST_TMP" "$DEST"
    trap - EXIT

    # awg-quick@out-warp resolves the config by interface name from
    # /etc/amnezia/amneziawg/out-warp.conf. Point that name at the canonical
    # config so there is a single source of truth (and the bot's pinned sudoers
    # paths stay valid). The symlink is mandatory for the systemd-owned interface.
    mkdir -p /etc/amnezia/amneziawg
    ln -sfn "$DEST" /etc/amnezia/amneziawg/out-warp.conf
    ;;
  remove)
    rm -f "$DEST" "$ROUTES_LIST" /etc/amnezia/amneziawg/out-warp.conf
    echo "WARP config removed"
    ;;
  *)
    echo "Usage: $0 {install <staged_config>|remove}" >&2
    exit 1
    ;;
esac
