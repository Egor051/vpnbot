#!/bin/bash
# Boot watchdog: if the WARP flip left the host's OWN egress inside the tunnel (the
# only way it can kill SSH), tear the tunnel routing down so the host falls back to
# its WAN uplink and SSH returns. A no-op when the host is healthy (egress not via
# the tunnel).
set +e
WARP_IFACE="${WARP_IFACE:-out-warp}"
WAN_DEV="${WAN_DEV:-eth0}"
WARP_FAILSAFE_DELAY="${WARP_FAILSAFE_DELAY:-75}"

sleep "$WARP_FAILSAFE_DELAY"   # let awg-quick@out-warp + warp-routes settle
route="$(ip route get 1.1.1.1 2>/dev/null)"
# Broken iff the host's own egress goes THROUGH the WARP tunnel. Testing for the
# tunnel interface (not a specific WAN device name) keeps the check correct on hosts
# whose WAN is not eth0, and avoids a false revert on transient loss of the default
# route. WAN_DEV is used only for the log messages.
if ! echo "$route" | grep -qw "dev $WARP_IFACE"; then
    logger -t warp-failsafe "host egress not via $WARP_IFACE (WAN $WAN_DEV) — healthy, no action"
    exit 0
fi
logger -t warp-failsafe "host egress via $WARP_IFACE ($route) — reverting to restore SSH"
systemctl stop warp-routes.service 2>/dev/null
systemctl stop "awg-quick@${WARP_IFACE}.service" 2>/dev/null
awg-quick down "$WARP_IFACE" 2>/dev/null
ip link del "$WARP_IFACE" 2>/dev/null
for t in $(ip -4 rule show 2>/dev/null | grep -oE 'lookup [0-9]+' | awk '{print $2}' | sort -u); do
    ip -4 rule del not fwmark "$t" table "$t" 2>/dev/null
    ip -6 rule del not fwmark "$t" table "$t" 2>/dev/null
done
ip -4 rule del table main suppress_prefixlength 0 2>/dev/null
ip -6 rule del table main suppress_prefixlength 0 2>/dev/null
logger -t warp-failsafe "revert complete — host should be reachable on $WAN_DEV"
exit 0
