#!/bin/bash
# vpnbot-warp-routes — add/remove the WARP routes read from routes.list.
# Default-equivalent routes are always skipped to prevent host isolation. No other
# CIDRs are hardcoded; the DNS resolver is never touched.
set -euo pipefail
ROUTES_LIST="/etc/amnezia/out-warp-routes.list"
ACTION="${1:-}"; IFACE="${2:-out-warp}"

# A route is "default-equivalent" when it has no prefix ("default") or a prefix
# length of 0 or 1. That covers the IPv4/IPv6 default routes and the "two halves"
# split-default trick (a pair of /1 routes that together cover every address).
# These are always skipped so the tunnel can never capture the host's whole egress.
is_default_route() {
    local net="$1" plen
    [[ "$net" == "default" ]] && return 0
    [[ "$net" != */* ]] && return 1
    plen="${net##*/}"
    [[ "$plen" =~ ^[0-9]+$ ]] || return 1
    (( plen <= 1 ))
}

apply_routes() {
    local net
    while IFS= read -r net; do
        [[ -z "$net" || "$net" == \#* ]] && continue
        if is_default_route "$net"; then
            echo "WARNING: skipping default-equivalent route $net (use an explicit routing table instead)" >&2
            continue
        fi
        ip route replace "$net" dev "$IFACE" metric 10 2>/dev/null || true
    done < "$ROUTES_LIST"
}

remove_routes() {
    local net
    while IFS= read -r net; do
        [[ -z "$net" || "$net" == \#* ]] && continue
        is_default_route "$net" && continue
        ip route del "$net" dev "$IFACE" 2>/dev/null || true
    done < "$ROUTES_LIST"
}

case "$ACTION" in
    add)
        [[ -f "$ROUTES_LIST" ]] || { echo "Routes list not found: $ROUTES_LIST" >&2; exit 1; }
        apply_routes
        # MASQUERADE: трафик из awg0/других интерфейсов меняет source на IP out-warp
        iptables -t nat -C POSTROUTING -o "$IFACE" -j MASQUERADE 2>/dev/null \
            || iptables -t nat -A POSTROUTING -o "$IFACE" -j MASQUERADE
        iptables -C FORWARD -i awg0 -o "$IFACE" -j ACCEPT 2>/dev/null \
            || iptables -I FORWARD -i awg0 -o "$IFACE" -j ACCEPT
        iptables -C FORWARD -i "$IFACE" -o awg0 -m state --state RELATED,ESTABLISHED -j ACCEPT 2>/dev/null \
            || iptables -I FORWARD -i "$IFACE" -o awg0 -m state --state RELATED,ESTABLISHED -j ACCEPT ;;
    del)
        # Tolerate a missing routes.list: the iptables teardown below must still run
        # so the NAT/FORWARD rules are never left dangling (idempotent teardown).
        [[ -f "$ROUTES_LIST" ]] && remove_routes
        iptables -t nat -D POSTROUTING -o "$IFACE" -j MASQUERADE 2>/dev/null || true
        iptables -D FORWARD -i awg0 -o "$IFACE" -j ACCEPT 2>/dev/null || true
        iptables -D FORWARD -i "$IFACE" -o awg0 -m state --state RELATED,ESTABLISHED -j ACCEPT 2>/dev/null || true ;;
    *)
        echo "Usage: $0 {add|del} <iface>" >&2; exit 1 ;;
esac
