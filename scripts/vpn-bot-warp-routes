#!/bin/bash
# vpn-bot-warp-routes — divert the VPN-client subnet out through the Cloudflare
# WARP AmneziaWG tunnel (out-warp) while the host itself stays on the direct path.
#
# Usage: vpn-bot-warp-routes <add|del> <iface>
#
# This is the production-proven recipe. The tunnel itself is brought up by
# awg-quick@out-warp with `Table = auto` in /etc/amnezia/out-warp.conf, which:
#   * sets an fwmark on the WireGuard socket so the tunnel's own encrypted
#     packets are never routed back into the tunnel (loop protection), and
#   * creates a dedicated routing table (the first free number it finds, equal
#     to the fwmark) whose default route is `dev out-warp`, plus the
#     host-bypass rules `not fwmark <T> table <T>` and
#     `table main suppress_prefixlength 0` that would otherwise send the WHOLE
#     host — including this SSH session — into the tunnel.
#
# `add` therefore (steps mirror the prod recipe):
#   1. reads the DYNAMIC table number T from `awg show <iface> fwmark`
#      (never hardcoded — awg-quick picks the first free one);
#   2. removes the host-bypass rules immediately so the host (SSH, the bot, apt)
#      keeps egressing directly — this is the critical safety step;
#   3. installs ONE narrow rule `from 10.0.0.0/24 lookup T` so only the AWG
#      client subnet uses the tunnel table;
#   4. pins the WARP endpoint to the real WAN gateway in BOTH the main and the
#      tunnel table (anti-loop; endpoint read at runtime, never hardcoded);
#   5. swaps the NAT — drops any direct `MASQUERADE -s 10.0.0.0/24 -o <wan>` and
#      adds `MASQUERADE -o out-warp`;
#   6. inserts the FORWARD accepts ABOVE UFW (`-I FORWARD 1`, both directions),
#      since UFW's FORWARD policy is DROP;
#   7. sets rp_filter=2 (loose) on all/out-warp/awg0 for the asymmetric path;
#   8. diverts LOCAL proxy egress (Dante/Xray/MTProto) through the tunnel too —
#      `from <tunnel-ip>` for the source-bind daemons and a cgroup-mark + explicit
#      SNAT for MTProto (which cannot source-bind). The tunnel IP is read from the
#      config's [Interface] Address; the MTProto step runs only when its unit exists.
# Finally it self-checks and rolls back to direct client egress if the check
# fails. The self-check verifies the host is NOT in the tunnel (host route +
# curl trace) and the client routing is installed (rule + tunnel-table default),
# then OBSERVES the tunnel's byte counters to confirm real client egress. It
# deliberately never simulates the client path with `ip route get`: that mark is
# set from conntrack, which the stateless `ip route get` cannot reproduce, so it
# would report false negatives. A quiet tunnel (no live client) skips the
# data-plane check rather than failing.
#
# `del` reverses everything (proxy egress first, then the client path) and restores
# the direct WAN MASQUERADE for the client subnet; it is safe to run on a clean
# system and when no proxy daemon is installed. It never restores the host-bypass —
# the host must always stay on the direct path. Neither the table number, the WARP
# endpoint nor the tunnel IP is hardcoded; all are read at runtime.
set -euo pipefail

ACTION="${1:-}"; IFACE="${2:-out-warp}"

# AmneziaWG client-facing interface and its subnet. The subnet is a SOURCE
# selector (which clients to divert), not a routing destination, and is the only
# literal CIDR baked in. Priority 1000 sits above the kernel's main-table rule so
# client packets reach the tunnel table, but it is a single narrow selector — the
# host's own (unmarked) traffic never matches it.
CLIENT_IFACE="awg0"
CLIENT_SUBNET="10.0.0.0/24"
CLIENT_RULE_PRIO=1000

# ── local-proxy egress through WARP ───────────────────────────────────────────
# Local egress proxies (Dante SOCKS5, Xray VLESS, MTProto) must ALSO leave through
# the tunnel, but they cannot be matched by source SUBNET: a locally-generated
# packet carries the host's real WAN IP, and `MASQUERADE -o out-warp` does NOT
# rewrite it (verified: masquerade rewrites FORWARDED client traffic but not
# locally-generated, fwmark-rerouted packets — they entered the tunnel with the
# host IP and WARP dropped them). The fix makes the inner src equal to the tunnel
# IP two ways:
#   * Source-bind daemons (Dante `external`, Xray `sendThrough`) already egress
#     with src == tunnel IP, so ONE rule diverts them and NO NAT is needed.
#   * MTProto/mtg cannot source-bind, so it is cgroup-marked and EXPLICITLY SNATed
#     to the tunnel IP, with the SNAT inserted ABOVE the broad out-warp MASQUERADE.
# Both priorities sit above the client rule (lower number = higher priority). The
# tunnel IP is read from the config's [Interface] Address — never hardcoded.
PROXY_RULE_PRIO=999
MTPROTO_RULE_PRIO=998
MTPROTO_MARK="0x2"

# WARP config the install helper writes; its [Interface] Address is the tunnel IP.
# Overridable so the helper can be exercised against a fixture.
WARP_CONFIG="${WARP_CONFIG:-/etc/amnezia/out-warp.conf}"

# ── runtime discovery (nothing below is hardcoded) ────────────────────────────

# Dynamic routing-table number == the fwmark awg-quick set for Table=auto.
# `awg show <iface> fwmark` prints it in hex (e.g. 0xca6c) or "off". Empty when
# the interface is down or the config has no default-route AllowedIPs.
warp_table() {
    local fw
    fw="$(awg show "$IFACE" fwmark 2>/dev/null || true)"
    [[ "$fw" =~ ^0x[0-9a-fA-F]+$ ]] && echo "$((fw))"
}

# WARP endpoint IPv4 (the encrypted tunnel's far side). Read from awg show so it
# is never baked in; this is what the anti-loop /32 route pins to the WAN.
warp_endpoint() {
    awg show "$IFACE" endpoints 2>/dev/null \
        | grep -oE '([0-9]{1,3}\.){3}[0-9]{1,3}' | head -n1
}

# Device of the main-table IPv4 default route (the real WAN uplink, e.g. eth0).
wan_dev() {
    ip -4 route show default 2>/dev/null \
        | awk '/^default/{for(i=1;i<=NF;i++) if($i=="dev"){print $(i+1); exit}}'
}

# Gateway of the main-table IPv4 default route (empty for a point-to-point WAN).
wan_gw() {
    ip -4 route show default 2>/dev/null \
        | awk '/^default/{for(i=1;i<=NF;i++) if($i=="via"){print $(i+1); exit}}'
}

# Tunnel IPv4 — the inner WARP address that proxy egress must be sourced from. Read
# from the config's [Interface] Address (first comma token, mask stripped); never
# hardcoded. Empty when the config is unreadable or carries no IPv4 Address.
tunnel_ip() {
    local line addr
    [[ -r "$WARP_CONFIG" ]] || return 0
    line="$(grep -iE '^[[:space:]]*Address[[:space:]]*=' "$WARP_CONFIG" 2>/dev/null | head -n1)"
    [[ -n "$line" ]] || return 0
    addr="${line#*=}"          # value after '='
    addr="${addr%%,*}"         # first comma-separated token (drop any IPv6)
    addr="${addr//[[:space:]]/}"  # trim whitespace
    addr="${addr%%/*}"         # strip the CIDR mask
    [[ "$addr" =~ ^([0-9]{1,3}\.){3}[0-9]{1,3}$ ]] && printf '%s\n' "$addr"
}

# systemd unit name of the MTProto proxy (mtg). Defaults to "mtproxy"; override via
# the MTPROXY_UNIT env when MTPROTO_SERVICE_NAME differs. An empty value disables
# the MTProto egress step entirely. A trailing ".service" is normalised away.
mtproxy_unit() {
    local u="${MTPROXY_UNIT-mtproxy}"
    printf '%s\n' "${u%.service}"
}

# True only when the resolved MTProto unit actually exists on this host, so the
# cgroup-mark recipe is applied solely where mtg is installed (safe otherwise).
mtproxy_unit_exists() {
    [[ -n "${1:-}" ]] || return 1
    command -v systemctl >/dev/null 2>&1 || return 1
    systemctl cat -- "${1}.service" >/dev/null 2>&1
}

# ── building blocks (idempotent) ──────────────────────────────────────────────

# Remove the awg-quick Table=auto host-bypass so the host stays on the direct
# path. `not fwmark T table T` captures every unmarked host packet and
# `table main suppress_prefixlength 0` overrides the host's own default route;
# together they tunnel the whole box. We strip both for v4 and v6.
strip_host_bypass() {
    local t="$1" fam
    for fam in -4 -6; do
        while ip "$fam" rule show 2>/dev/null | grep -q "lookup $t"; do
            ip "$fam" rule del not fwmark "$t" table "$t" 2>/dev/null || break
        done
        while ip "$fam" rule show 2>/dev/null | grep -q "lookup main suppress_prefixlength 0"; do
            ip "$fam" rule del table main suppress_prefixlength 0 2>/dev/null || break
        done
    done
}

# Restore the direct WAN MASQUERADE for the client subnet (used by del/rollback
# so clients still reach the internet once the tunnel path is gone).
restore_direct_masquerade() {
    local dev; dev="$(wan_dev)"
    [[ -n "$dev" ]] || return 0
    iptables -t nat -C POSTROUTING -s "$CLIENT_SUBNET" -o "$dev" -j MASQUERADE 2>/dev/null \
        || iptables -t nat -A POSTROUTING -s "$CLIENT_SUBNET" -o "$dev" -j MASQUERADE
}

# Tear down everything `add` installs and return clients to direct egress. Safe
# to call on a clean system; never touches the host-bypass (host stays direct).
teardown_client_routing() {
    local t ep dev
    t="$(warp_table || true)"
    ep="$(warp_endpoint || true)"
    dev="$(wan_dev)"

    # 7. Proxy egress (reverse of add: removed before the client routing it rides on).
    remove_proxy_routing "$t"

    # 6. FORWARD accepts (removed first, reverse order).
    iptables -D FORWARD -i "$IFACE" -o "$CLIENT_IFACE" -j ACCEPT 2>/dev/null || true
    iptables -D FORWARD -i "$CLIENT_IFACE" -o "$IFACE" -j ACCEPT 2>/dev/null || true

    # 5. NAT: drop the out-warp MASQUERADE, restore the direct one for clients.
    iptables -t nat -D POSTROUTING -o "$IFACE" -j MASQUERADE 2>/dev/null || true
    restore_direct_masquerade

    # 3. Narrow client rule (table-independent: match the selector + priority).
    while ip -4 rule show 2>/dev/null | grep -q "from $CLIENT_SUBNET lookup"; do
        ip -4 rule del from "$CLIENT_SUBNET" priority "$CLIENT_RULE_PRIO" 2>/dev/null || break
    done

    # 4. Anti-loop endpoint pin (main + tunnel table).
    if [[ -n "$ep" ]]; then
        ip route del "$ep/32" 2>/dev/null || true
        [[ -n "$t" ]] && ip route del "$ep/32" table "$t" 2>/dev/null || true
    fi
}

# Divert local proxy egress (Dante/Xray/MTProto) through the tunnel. Idempotent and
# safe when no proxy daemon is installed. Source-bind daemons need only the
# `from <tunnel-ip>` rule; MTProto additionally needs the cgroup-mark + SNAT.
apply_proxy_routing() {
    local t="$1" tip unit cgpath
    tip="$(tunnel_ip || true)"
    if [[ -z "$tip" ]]; then
        echo "WARNING: no tunnel IP in $WARP_CONFIG [Interface] Address; skipping proxy egress" >&2
        return 0
    fi

    # Source-bind proxies: src is already the tunnel IP → one rule into table T.
    # No NAT (the source is correct). Priority sits above the client subnet rule.
    ip -4 rule show | grep -q "from $tip lookup $t" \
        || ip -4 rule add from "$tip" lookup "$t" priority "$PROXY_RULE_PRIO"

    # MTProto (mtg) cannot source-bind: cgroup-mark its egress and SNAT to the tunnel
    # IP. Applied ONLY when the unit exists; a no-op (and safe) otherwise.
    unit="$(mtproxy_unit)"
    mtproxy_unit_exists "$unit" || return 0
    cgpath="system.slice/${unit}.service"

    # a. Marked packets use the tunnel table (priority above the source-bind rule).
    ip -4 rule show | grep -q "fwmark $MTPROTO_MARK lookup $t" \
        || ip -4 rule add fwmark "$MTPROTO_MARK" lookup "$t" priority "$MTPROTO_RULE_PRIO"

    # b. Mark the daemon's locally-generated packets by its cgroup. Non-fatal: the
    #    cgroup only materialises once mtg is running, so a boot-time apply that runs
    #    before it starts just warns (the unit's drop-in re-applies on start).
    iptables -t mangle -C OUTPUT -m cgroup --path "$cgpath" -j MARK --set-mark "$MTPROTO_MARK" 2>/dev/null \
        || iptables -t mangle -A OUTPUT -m cgroup --path "$cgpath" -j MARK --set-mark "$MTPROTO_MARK" 2>/dev/null \
        || echo "WARNING: could not cgroup-mark $cgpath (is $unit running?); MTProto masking applies once it starts" >&2

    # c. Explicit SNAT to the tunnel IP, INSERTED (-I 1) ABOVE the broad out-warp
    #    MASQUERADE so the marked packets get the tunnel source before masquerade.
    iptables -t nat -C POSTROUTING -o "$IFACE" -m mark --mark "$MTPROTO_MARK" -j SNAT --to-source "$tip" 2>/dev/null \
        || iptables -t nat -I POSTROUTING 1 -o "$IFACE" -m mark --mark "$MTPROTO_MARK" -j SNAT --to-source "$tip"
}

# Reverse of apply_proxy_routing. Safe on a clean system and when no proxy daemon is
# present; every deletion swallows "rule not present".
remove_proxy_routing() {
    local t="$1" tip unit cgpath
    tip="$(tunnel_ip || true)"
    unit="$(mtproxy_unit)"
    cgpath="system.slice/${unit}.service"

    # MTProto teardown (reverse: SNAT → cgroup-mark → fwmark rule).
    if [[ -n "$tip" ]]; then
        iptables -t nat -D POSTROUTING -o "$IFACE" -m mark --mark "$MTPROTO_MARK" -j SNAT --to-source "$tip" 2>/dev/null || true
    fi
    if [[ -n "$unit" ]]; then
        iptables -t mangle -D OUTPUT -m cgroup --path "$cgpath" -j MARK --set-mark "$MTPROTO_MARK" 2>/dev/null || true
    fi
    while ip -4 rule show 2>/dev/null | grep -q "fwmark $MTPROTO_MARK lookup"; do
        ip -4 rule del fwmark "$MTPROTO_MARK" priority "$MTPROTO_RULE_PRIO" 2>/dev/null || break
    done

    # Source-bind proxy rule.
    if [[ -n "$tip" ]]; then
        while ip -4 rule show 2>/dev/null | grep -q "from $tip lookup"; do
            ip -4 rule del from "$tip" priority "$PROXY_RULE_PRIO" 2>/dev/null || break
        done
    fi
}

# Self-check — how far a valid probe can go in a conntrack-mark architecture.
#
# The client subnet is steered into the tunnel table by an fwmark that nftables
# sets FROM CONNTRACK (`ct mark set meta mark` / `meta mark <m> ct mark set meta
# mark`). `ip route get` is a STATELESS simulation with no conntrack state: it
# cannot reproduce a real packet's mark, so every form of it — `iif`, `mark`,
# bare `from <client>` — structurally mis-measures conntrack-mark routing and
# yields FALSE NEGATIVES (the simulated packet resolves to the WAN even while
# real client egress rides out-warp). We therefore NEVER probe the client path
# with `ip route get`; we OBSERVE the real data plane instead (byte counters).
#
# Two kinds of check live here:
#   * HOST checks (SSH safety) — the host must NOT be captured by the tunnel.
#     These are HOST routes / the host's own curl: no conntrack is involved, so
#     `ip route get 1.1.1.1` (no from/iif) and a `warp=off` trace measure them
#     correctly. A failure is dangerous (it would tunnel SSH) and DOES roll back.
#   * CLIENT checks — control plane (the narrow rule + tunnel-table default are
#     actually installed; conntrack-independent, deterministic) plus a data-plane
#     OBSERVATION of tunnel byte counters. The observation confirms-or-skips and
#     never rolls back: growth proves egress rides out-warp, but a flat counter is
#     ambiguous (an idle/absent client is not a broken tunnel), so it must not
#     fail. Rollback teeth stay with the host checks and the control-plane presence.

# Recent-handshake window (seconds) within which an awg0 peer counts as a live
# client worth measuring. Overridable for tests.
CLIENT_HANDSHAKE_WINDOW="${CLIENT_HANDSHAKE_WINDOW:-180}"
# Interval (seconds) between the two tunnel-counter samples. Overridable for tests.
SELF_CHECK_INTERVAL="${SELF_CHECK_INTERVAL:-4}"

# Total bytes seen on the tunnel netdev (rx+tx). Prefer the kernel counters in
# sysfs (one integer each, cheapest and always current); fall back to summing the
# per-peer counters `awg show <iface> transfer` reports. Prints one integer.
#
# TEST SEAM (inert in production — MOCK_TRANSFER_STEP is NEVER set in the field):
# the counter-growth injection the self-check tests rely on lives in the mockable
# `awg show <iface> transfer` fallback, so the sysfs fast-path MUST be skipped
# whenever that injection is active. Guard it BEFORE the `-r /sys/...` probe rather
# than after: on a real host the tunnel netdev exists, so its /sys statistics ARE
# readable and — sampled across a short interval — momentarily flat. If the fast-
# path ran it would read those live, flat counters and ignore the injected growth,
# making the regression test that is green in CI (no tunnel netdev → fast-path
# unreadable → fallback → mock honoured) FALSELY SKIP on the host (netdev present →
# fast-path wins → mock bypassed). Bypassing the fast-path in test mode makes the
# counter source deterministic regardless of whether the interface exists on the
# machine running the tests. Production takes the sysfs path exactly as before.
warp_bytes() {
    local rx tx sum=0 _pk
    if [[ -z "${MOCK_TRANSFER_STEP:-}" \
       && -r "/sys/class/net/$IFACE/statistics/rx_bytes" \
       && -r "/sys/class/net/$IFACE/statistics/tx_bytes" ]]; then
        rx="$(cat "/sys/class/net/$IFACE/statistics/rx_bytes" 2>/dev/null || true)"
        tx="$(cat "/sys/class/net/$IFACE/statistics/tx_bytes" 2>/dev/null || true)"
        if [[ "$rx" =~ ^[0-9]+$ && "$tx" =~ ^[0-9]+$ ]]; then
            echo "$((rx + tx))"; return 0
        fi
    fi
    # `awg show <iface> transfer` → "<pubkey>\t<rx>\t<tx>" per peer.
    while IFS=$'\t' read -r _pk rx tx; do
        [[ "$rx" =~ ^[0-9]+$ ]] && sum=$((sum + rx))
        [[ "$tx" =~ ^[0-9]+$ ]] && sum=$((sum + tx))
    done < <(awg show "$IFACE" transfer 2>/dev/null || true)
    echo "$sum"
}

# True when at least one client peer completed a handshake within the window —
# i.e. a live client whose egress the counter sample could actually observe. The
# peer list is read from `awg show <client-iface> latest-handshakes`; no client IP
# is ever hardcoded. A stale peer (old or zero handshake) does not count.
have_active_clients() {
    local now _pk ts
    now="$(date +%s 2>/dev/null || echo 0)"
    [[ "$now" -gt 0 ]] || return 1
    while read -r _pk ts; do
        [[ "$ts" =~ ^[0-9]+$ ]] || continue
        (( ts > 0 && now - ts <= CLIENT_HANDSHAKE_WINDOW )) && return 0
    done < <(awg show "$CLIENT_IFACE" latest-handshakes 2>/dev/null || true)
    return 1
}

# Data-plane observation of client egress. Does NOT simulate the path (see the
# block comment above) — it samples the tunnel byte counters across a short
# interval. Growth while a client is connected proves egress really rides the
# tunnel. With no live client there is nothing to measure, so it SKIPS. It never
# returns failure: a flat counter cannot distinguish "idle" from "broken", and
# failing on that ambiguity is exactly the false-negative rollback we are fixing.
check_client_dataplane() {
    local before after
    if ! have_active_clients; then
        echo "self-check: no live clients on $CLIENT_IFACE (recent handshake) — skipping data-plane check; an idle tunnel is not a broken one" >&2
        return 0
    fi
    before="$(warp_bytes)"
    sleep "$SELF_CHECK_INTERVAL"
    after="$(warp_bytes)"
    if [[ "$before" =~ ^[0-9]+$ && "$after" =~ ^[0-9]+$ && "$after" -gt "$before" ]]; then
        echo "self-check: $IFACE counters grew ${before}→${after} B — client egress via the tunnel confirmed" >&2
    else
        echo "self-check: $IFACE counters flat (${before}→${after} B) with a live client — inconclusive (client may be idle); skipping the data-plane assertion" >&2
    fi
    return 0
}

# Self-check: the host must NOT be inside the tunnel, the client routing MUST be
# installed, and — when there is traffic to observe — the client subnet's egress
# is confirmed via real counters (never via a stateless `ip route get`). Returns
# non-zero only on host capture or a missing client route.
self_check() {
    local t="$1" rc=0 trace

    # HOST egress must stay on the direct path (SSH safety). A HOST route, no
    # conntrack involved, so `ip route get` measures it correctly. If the
    # host-bypass were still present a locally-originated unmarked packet would
    # resolve to out-warp.
    if ip route get 1.1.1.1 2>/dev/null | grep -q "dev $IFACE"; then
        echo "self-check FAILED: host egress is inside the WARP tunnel" >&2
        rc=1
    fi

    # CLIENT control plane: the narrow client rule and the tunnel-table default
    # via out-warp must actually be present. This is conntrack-independent, so a
    # missing rule is a genuine install failure worth rolling back — unlike a
    # stateless `ip route get` of the client path, which is structurally invalid.
    if ! { ip -4 rule show 2>/dev/null | grep -q "from $CLIENT_SUBNET lookup $t" \
           && ip -4 route show table "$t" 2>/dev/null | grep -q "dev $IFACE"; }; then
        echo "self-check FAILED: client routing not installed (rule/table missing for $CLIENT_SUBNET via $IFACE)" >&2
        rc=1
    fi

    # CLIENT data plane: observe real egress instead of simulating it. Confirms or
    # skips; never fails (see check_client_dataplane).
    check_client_dataplane

    # Best-effort: the host's own curl must report warp=off (it must NOT egress
    # through the tunnel). Skipped when curl or the network is unavailable.
    if command -v curl >/dev/null 2>&1; then
        trace="$(curl -s --max-time 6 https://www.cloudflare.com/cdn-cgi/trace 2>/dev/null || true)"
        if printf '%s\n' "$trace" | grep -qE '^warp=(on|plus)'; then
            echo "self-check FAILED: host curl reports warp on (host egress is tunneled)" >&2
            rc=1
        fi
    fi
    return "$rc"
}

case "$ACTION" in
    add)
        [[ -n "$IFACE" ]] || { echo "Interface required" >&2; exit 1; }

        # 1. Dynamic tunnel table from the fwmark awg-quick set for Table=auto.
        TABLE="$(warp_table || true)"
        if [[ -z "$TABLE" ]]; then
            echo "ERROR: $IFACE has no auto routing table (awg show $IFACE fwmark = off)." >&2
            echo "       The config must set 'Table = auto' with a default-route" >&2
            echo "       AllowedIPs (0.0.0.0/0), and the interface must be up." >&2
            exit 1
        fi

        # 2. CRITICAL: strip the host-bypass first so the host never stays in the
        #    tunnel (a dropped SSH session here would mean a reboot).
        strip_host_bypass "$TABLE"

        # 3. Narrow client rule: only 10.0.0.0/24 uses the tunnel table.
        ip -4 rule show | grep -q "from $CLIENT_SUBNET lookup $TABLE" \
            || ip -4 rule add from "$CLIENT_SUBNET" lookup "$TABLE" priority "$CLIENT_RULE_PRIO"

        # 4. Anti-loop: pin the WARP endpoint to the real WAN gateway in BOTH the
        #    main table and the tunnel table so neither the host's WG socket nor a
        #    client destined for the endpoint IP is routed back into the tunnel.
        WAN_DEV="$(wan_dev)"; WAN_GW="$(wan_gw)"
        WARP_ENDPOINT="$(warp_endpoint || true)"
        if [[ -n "$WARP_ENDPOINT" && -n "$WAN_DEV" ]]; then
            if [[ -n "$WAN_GW" ]]; then
                ip route replace "$WARP_ENDPOINT/32" via "$WAN_GW" dev "$WAN_DEV"
                ip route replace "$WARP_ENDPOINT/32" via "$WAN_GW" dev "$WAN_DEV" table "$TABLE"
            else
                ip route replace "$WARP_ENDPOINT/32" dev "$WAN_DEV"
                ip route replace "$WARP_ENDPOINT/32" dev "$WAN_DEV" table "$TABLE"
            fi
        else
            echo "WARNING: could not resolve WARP endpoint or WAN device; skipping anti-loop pin" >&2
        fi

        # 5. NAT: drop any direct client MASQUERADE on the WAN device, then add
        #    the MASQUERADE on the tunnel so client egress shows the WARP IP.
        if [[ -n "$WAN_DEV" ]]; then
            while iptables -t nat -C POSTROUTING -s "$CLIENT_SUBNET" -o "$WAN_DEV" -j MASQUERADE 2>/dev/null; do
                iptables -t nat -D POSTROUTING -s "$CLIENT_SUBNET" -o "$WAN_DEV" -j MASQUERADE
            done
        fi
        iptables -t nat -C POSTROUTING -o "$IFACE" -j MASQUERADE 2>/dev/null \
            || iptables -t nat -A POSTROUTING -o "$IFACE" -j MASQUERADE

        # 6. FORWARD above UFW (UFW's FORWARD policy is DROP). Insert at the top.
        iptables -C FORWARD -i "$CLIENT_IFACE" -o "$IFACE" -j ACCEPT 2>/dev/null \
            || iptables -I FORWARD 1 -i "$CLIENT_IFACE" -o "$IFACE" -j ACCEPT
        iptables -C FORWARD -i "$IFACE" -o "$CLIENT_IFACE" -j ACCEPT 2>/dev/null \
            || iptables -I FORWARD 1 -i "$IFACE" -o "$CLIENT_IFACE" -j ACCEPT

        # 7. Loose reverse-path filtering for the asymmetric tunnel path.
        for rp in all "$IFACE" "$CLIENT_IFACE"; do
            sysctl -w "net.ipv4.conf.$rp.rp_filter=2" >/dev/null 2>&1 || true
        done

        # 8. Divert local proxy egress (Dante/Xray/MTProto) through the tunnel too.
        apply_proxy_routing "$TABLE"

        # 9. Verify, and roll back to direct client egress on any failure.
        if ! self_check "$TABLE"; then
            echo "ERROR: self-check failed — rolling back to direct client egress" >&2
            teardown_client_routing
            strip_host_bypass "$TABLE"
            exit 1
        fi
        ;;
    del)
        teardown_client_routing
        ;;
    proxy-add)
        # Apply ONLY the local-proxy egress rules (no host/client routing, no
        # destructive self-check). Used by the MTProto unit's privileged
        # ExecStartPost to (re)assert the cgroup-mark once its cgroup exists — the
        # `-m cgroup --path` match can only be added while the daemon is running.
        # Idempotent and safe to call repeatedly.
        TABLE="$(warp_table || true)"
        if [[ -z "$TABLE" ]]; then
            echo "ERROR: $IFACE has no auto routing table; cannot apply proxy egress" >&2
            exit 1
        fi
        apply_proxy_routing "$TABLE"
        ;;
    proxy-del)
        # Remove ONLY the local-proxy egress rules; leaves host/client routing intact.
        remove_proxy_routing "$(warp_table || true)"
        ;;
    *)
        echo "Usage: $0 {add|del|proxy-add|proxy-del} <iface>" >&2; exit 1 ;;
esac
