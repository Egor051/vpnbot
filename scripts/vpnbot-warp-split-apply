#!/usr/bin/env bash
# vpnbot-warp-split-apply — privileged helper: validate + atomically write warp-split.list.
#
# Reads the desired CIDR list from stdin (one entry per line; blank lines and
# lines starting with # are allowed and passed through as-is). Any non-blank
# non-comment line that is not a valid IPv4 CIDR with an explicit prefix length
# causes the helper to abort with exit status 1 — nothing is written.
#
# On success: writes SPLIT_LIST atomically (temp rename in the same directory,
# root:root 0644) then restarts vpnbot-warp-split via systemctl.
#
# Defence-in-depth: this helper provides syntactic safety only. The calling bot
# is responsible for policy decisions (which prefixes are allowed, dedup, etc.).
# A compromised bot cannot write arbitrary content as root because every
# non-comment line is validated against ipaddress.ip_network.
#
# Usage (bot calls via sudo -n):
#   printf '%s\n' "1.2.3.0/24" "5.6.0.0/16" | sudo -n vpnbot-warp-split-apply
#
set -euo pipefail

# Security: when invoked via sudo (SUDO_UID is set by sudo and survives env_reset),
# ignore a caller-supplied WARP_SPLIT_LIST_PATH and write only the fixed list path
# (defense-in-depth beyond sudoers env_reset). Non-sudo callers (the test harness)
# may still override via WARP_SPLIT_LIST_PATH.
if [ -n "${SUDO_UID:-}" ]; then
    SPLIT_LIST="/etc/vpnbot/warp-split.list"
else
    SPLIT_LIST="${WARP_SPLIT_LIST_PATH:-/etc/vpnbot/warp-split.list}"
fi
ME="vpnbot-warp-split-apply"

# Read all stdin before doing anything — reject immediately on empty.
content="$(cat)"
if [ -z "$content" ]; then
    echo "${ME}: empty stdin — refusing to write empty list" >&2
    exit 1
fi

# Validate every non-blank, non-comment line with python3 ipaddress.
# One python3 invocation for the whole input (fast; no repeated exec overhead).
# The script is in single quotes so bash does not expand anything inside it.
if ! printf '%s\n' "$content" | python3 -c '
import sys, ipaddress

errors = []
valid_count = 0
for lineno, raw in enumerate(sys.stdin, 1):
    line = raw.split("#", 1)[0].strip()
    if not line:
        continue
    valid_count += 1
    # Mask is mandatory — bare IP is rejected so a mistyped /32 cannot silently
    # become a host route in ways that surprise the operator.
    if "/" not in line:
        errors.append(f"line {lineno}: missing prefix length (bare IP not allowed): {line!r}")
        continue
    try:
        net = ipaddress.ip_network(line, strict=True)
    except ValueError as exc:
        errors.append(f"line {lineno}: invalid CIDR {line!r}: {exc}")
        continue
    if net.version != 4:
        errors.append(f"line {lineno}: only IPv4 allowed (got version {net.version}): {line!r}")

if errors:
    for e in errors:
        print(f"error: {e}", file=sys.stderr)
    sys.exit(1)
if valid_count == 0:
    print("error: no valid CIDR entries in input (all lines blank/comment)", file=sys.stderr)
    sys.exit(1)
'; then
    echo "${ME}: validation failed — nothing written" >&2
    exit 1
fi

# Atomic write: create temp in the same directory so rename is on one fs.
SPLIT_DIR="$(dirname "$SPLIT_LIST")"
tmpfile="$(mktemp "${SPLIT_DIR}/.warp-split-tmp.XXXXXX")"
# Ensure temp is cleaned up on unexpected exit before the rename.
trap 'rm -f "$tmpfile"' EXIT

printf '%s\n' "$content" > "$tmpfile"
chown root:root "$tmpfile"
chmod 0644 "$tmpfile"
# Atomic replace (rename is atomic on POSIX when src/dst are on the same fs).
mv "$tmpfile" "$SPLIT_LIST"
# Cancel the trap — file was successfully renamed.
trap - EXIT

n_prefixes="$(printf '%s\n' "$content" | grep -cvE '^\s*(#|$)' || true)"
echo "${ME}: wrote ${n_prefixes} prefix(es) to ${SPLIT_LIST}"

systemctl restart vpnbot-warp-split
echo "${ME}: vpnbot-warp-split restarted"
