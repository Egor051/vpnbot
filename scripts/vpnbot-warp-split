#!/usr/bin/env bash
# vpnbot-warp-split — selective WARP: listed prefixes via out-warp, rest direct via eth0.
# Runs AFTER vpnbot-warp-routes (full-tunnel setup). Host stays direct — never touches main/SSH.
set -euo pipefail

IFACE="${WARP_IFACE:-out-warp}"
# WAN uplink: default to the interface of the main-table default route (portable to
# ens3/enp1s0/… names), not a hardcoded eth0. Still overridable via WAN_DEV.
WAN_DEV="${WAN_DEV:-$(ip route show default 2>/dev/null | awk '/^default/{for(i=1;i<=NF;i++) if($i=="dev"){print $(i+1); exit}}' || true)}"
WAN_DEV="${WAN_DEV:-eth0}"
PROXY_SRC="${WARP_PROXY_SRC:-172.16.0.2}"
CLIENT_NET="${WARP_CLIENT_NET:-10.0.0.0/24}"
# WARP endpoint: default to the live endpoint from `awg show` (never hardcoded) so a
# non-Cloudflare / self-hosted endpoint still gets the correct anti-loop /32 pin.
ENDPOINT_IP="${WARP_ENDPOINT_IP:-$(awg show "$IFACE" endpoints 2>/dev/null | grep -oE '([0-9]{1,3}\.){3}[0-9]{1,3}' | head -n1 || true)}"
# Security: when invoked via sudo (SUDO_UID set by sudo, survives env_reset), ignore
# caller-supplied path overrides for the list and the intent marker and use the fixed
# defaults (defense-in-depth beyond sudoers env_reset). Non-sudo callers (the systemd
# unit, tests) may still override via env.
if [ -n "${SUDO_UID:-}" ]; then
    LIST="/etc/vpnbot/warp-split.list"
    MARKER="/etc/vpnbot/warp-split.disabled"
else
    LIST="${WARP_SPLIT_LIST:-/etc/vpnbot/warp-split.list}"
    # Root-owned intent marker: when present the split routing is "off" — table T is
    # reconciled to EMPTY (all-direct) instead of to the list. Written/removed by the
    # vpnbot-warp-split-state helper; honoured here so an "off" state survives reboot.
    MARKER="${WARP_SPLIT_DISABLED_MARKER:-/etc/vpnbot/warp-split.disabled}"
fi
log(){ echo "[warp-split] $*"; }

fwmark="$(awg show "$IFACE" fwmark 2>/dev/null || true)"
[ -n "$fwmark" ] && [ "$fwmark" != off ] || { log "no fwmark for $IFACE (tunnel down?) — abort, routing left as-is"; exit 0; }
# Validate the hex shape before the arithmetic table conversion (parity with
# vpnbot-warp-routes) so a malformed fwmark never reaches $(( )).
case "$fwmark" in
  0x[0-9a-fA-F]*) : ;;
  *) log "unexpected fwmark '$fwmark' for $IFACE — abort"; exit 0 ;;
esac
T=$(( fwmark ))
GW="$(ip route show default dev "$WAN_DEV" | awk '/default/{print $3; exit}')"
[ -n "$GW" ] || { log "no default gw on $WAN_DEV — abort"; exit 0; }
log "table T=$T iface=$IFACE wan=$WAN_DEV gw=$GW"

case "${1:-apply}" in
apply)
  # Boot/state honour: if the disabled marker is present, reconcile table T to
  # EMPTY (all-direct) instead of to the list. Only script-managed per-prefix
  # `<prefix> dev $IFACE` routes are retracted (the #164 reconcile loop with an
  # empty want-set). The anti-loop endpoint route, ip rules and NAT/FORWARD are
  # left untouched, and the saved list file is NOT modified — re-applied on "on".
  if [ -e "$MARKER" ]; then
    ip route show table "$T" 2>/dev/null \
      | awk -v dev="$IFACE" '$1!="default" && $2=="dev" && $3==dev {print $1}' \
      | while read -r old; do
          ip route del "$old" dev "$IFACE" table "$T" 2>/dev/null || true
        done || true
    log "split DISABLED by marker $MARKER — per-prefix WARP routes flushed from table $T (all direct)"
    exit 0
  fi
  [ -s "$LIST" ] || { log "empty/missing $LIST — abort (refuse to blackhole)"; exit 0; }
  ip route del default dev "$IFACE" table "$T" 2>/dev/null || true
  if [ -n "$ENDPOINT_IP" ]; then
    ip route replace "$ENDPOINT_IP/32" via "$GW" dev "$WAN_DEV" table "$T"
  else
    log "WARNING: no WARP endpoint resolved — skipping anti-loop /32 pin"
  fi
  # Build the wanted prefix set from the list (comments/blanks/default-routes dropped).
  WANT=" "
  while read -r pfx; do
    pfx="${pfx%%#*}"; pfx="${pfx//[[:space:]]/}"
    [ -n "$pfx" ] || continue
    case "$pfx" in 0.0.0.0/0|::/0) continue;; esac
    case "$WANT" in *" $pfx "*) ;; *) WANT="$WANT$pfx ";; esac
  done < "$LIST"
  # Reconcile: drop script-managed per-prefix routes (`<prefix> dev $IFACE`) in
  # table T that are no longer listed, so a removed prefix stops using WARP after
  # restart instead of lingering until reboot. Only `dev $IFACE` routes are touched
  # — the anti-loop (`$ENDPOINT_IP/32 via $GW dev $WAN_DEV`) is `dev $WAN_DEV`, never
  # matched; the table default was already removed above.
  ip route show table "$T" 2>/dev/null \
    | awk -v dev="$IFACE" '$1!="default" && $2=="dev" && $3==dev {print $1}' \
    | while read -r old; do
        case "$WANT" in
          *" $old "*) : ;;                                       # still wanted — keep
          *) ip route del "$old" dev "$IFACE" table "$T" 2>/dev/null || true ;;
        esac
      done || true
  # Add/refresh the wanted prefixes (`replace` is idempotent — no dups on re-apply).
  for pfx in $WANT; do
    ip route replace "$pfx" dev "$IFACE" table "$T"
  done
  log "table T is now selective ($(grep -cvE '^\s*(#|$)' "$LIST") prefixes)"
  for SRC in "$CLIENT_NET" "$PROXY_SRC"; do
    iptables -t nat -C POSTROUTING -s "$SRC" -o "$WAN_DEV" -j MASQUERADE 2>/dev/null \
      || iptables -t nat -A POSTROUTING -s "$SRC" -o "$WAN_DEV" -j MASQUERADE
  done
  iptables -C FORWARD -i awg0 -o "$WAN_DEV" -j ACCEPT 2>/dev/null \
    || iptables -I FORWARD 1 -i awg0 -o "$WAN_DEV" -j ACCEPT
  iptables -C FORWARD -i "$WAN_DEV" -o awg0 -m state --state RELATED,ESTABLISHED -j ACCEPT 2>/dev/null \
    || iptables -I FORWARD 1 -i "$WAN_DEV" -o awg0 -m state --state RELATED,ESTABLISHED -j ACCEPT
  log "selective WARP applied"
  ;;
revert)
  ip route replace default dev "$IFACE" table "$T"
  iptables -t nat -D POSTROUTING -s "$CLIENT_NET" -o "$WAN_DEV" -j MASQUERADE 2>/dev/null || true
  iptables -t nat -D POSTROUTING -s "$PROXY_SRC"  -o "$WAN_DEV" -j MASQUERADE 2>/dev/null || true
  log "reverted to full-tunnel (default dev $IFACE restored in table $T)"
  ;;
*) echo "usage: $0 {apply|revert}" >&2; exit 2;;
esac
